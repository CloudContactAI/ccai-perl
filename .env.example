# CCAI API Credentials
# Copy this file to .env and fill in your actual credentials

# Your CCAI Client ID
CCAI_CLIENT_ID=your-client-id-here

# Your CCAI API Key
CCAI_API_KEY=your-api-key-here

# Phone numbers for integration tests (E.164 format)
# CCAI_TEST_PHONE=+15551234567
# CCAI_TEST_PHONE_2=+15557654321   # second number for bulk SMS and Contact tests
# CCAI_TEST_EMAIL=you@example.com

# Optional: Enable debug mode
# CCAI_DEBUG=1

# Optional: Suppress LWP Content-Length warnings (set to 1 to enable)
# CCAI_SUPPRESS_WARNINGS=1
